{
  "name": "pkg-placeholder",
  "version": "0.0.1",
  "description": "_description_",
  "keywords": [
    "pkg-placeholder"
  ],
  "homepage": "https://github.com/ericc-ch/pkg-placeholder",
  "bugs": "https://github.com/ericc-ch/pkg-placeholder/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ericc-ch/pkg-placeholder.git"
  },
  "author": {
    "name": "Erick Christian",
    "email": "erickchristian48@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.mjs"
    }
  },
  "bin": {
    "pkg-placeholder": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write .",
    "lint": "oxlint --type-aware",
    "prepare": "simple-git-hooks && effect-language-service patch",
    "prepack": "pnpm run build",
    "release": "bumpp && npm publish",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run format",
    "pre-push": "pnpm run typecheck && pnpm test && pnpm run lint"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.43",
    "effect": "^4.0.0-beta.43",
    "env-paths": "^4.0.0",
    "jiti": "^2.5.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.2",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
