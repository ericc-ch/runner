{
  "name": "pkg-placeholder",
  "version": "0.0.1",
  "description": "_description_",
  "keywords": [
    "pkg-placeholder"
  ],
  "homepage": "https://github.com/ericc-ch/pkg-placeholder",
  "bugs": "https://github.com/ericc-ch/pkg-placeholder/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ericc-ch/pkg-placeholder.git"
  },
  "author": {
    "name": "Erick Christian",
    "email": "erickchristian48@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.mjs"
    }
  },
  "bin": {
    "pkg-placeholder": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write .",
    "lint": "oxlint --type-aware",
    "prepare": "simple-git-hooks && effect-language-service patch",
    "prepack": "pnpm run build",
    "release": "bumpp && npm publish",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsgo"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run format",
    "pre-push": "pnpm run typecheck && pnpm test && pnpm run lint"
  },
  "dependencies": {
    "@effect/cli": "^0.73.1",
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.94.2",
    "effect": "^3.19.15",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.72.0",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.35",
    "@typescript/native-preview": "^7.0.0-dev.20260130.1",
    "bumpp": "^10.4.0",
    "oxlint": "^1.42.0",
    "oxlint-tsgolint": "^0.11.3",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
